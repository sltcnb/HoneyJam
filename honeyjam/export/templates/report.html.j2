<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>HoneyJam Report</title>
<style>
  :root { color-scheme: light dark; }
  body { font-family: -apple-system, Segoe UI, Roboto, sans-serif; margin: 0; background:#0f1115; color:#e6e6e6; }
  header { background:#f5a623; color:#1a1a1a; padding:20px 28px; }
  header h1 { margin:0; font-size:24px; }
  header .sub { font-size:13px; opacity:.8; }
  .wrap { padding: 24px 28px; }
  .cards { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:24px; }
  .card { background:#1b1e26; border-radius:10px; padding:14px 18px; min-width:110px; }
  .card .n { font-size:26px; font-weight:700; }
  .card .l { font-size:12px; text-transform:uppercase; opacity:.7; }
  table { border-collapse:collapse; width:100%; margin-bottom:32px; background:#1b1e26; border-radius:8px; overflow:hidden; }
  th, td { text-align:left; padding:8px 10px; font-size:13px; border-bottom:1px solid #2a2e39; vertical-align:top; }
  th { background:#242833; text-transform:uppercase; font-size:11px; letter-spacing:.5px; }
  td.data { font-family:monospace; word-break:break-all; max-width:480px; }
  .sev { padding:2px 8px; border-radius:12px; font-size:11px; font-weight:700; text-transform:uppercase; }
  .critical { background:#7c1d1d; color:#ffdada; }
  .high { background:#a33; color:#ffe0e0; }
  .medium { background:#a76c00; color:#fff3d6; }
  .low { background:#2f5d8a; color:#d8ecff; }
  .info { background:#33384a; color:#c9d1e6; }
  h2 { margin-top:8px; font-size:18px; }
  .plugin-desc { font-size:12px; opacity:.7; margin:-6px 0 10px; }
  .empty { opacity:.6; font-style:italic; }
  footer { padding:16px 28px; font-size:12px; opacity:.6; }
</style>
</head>
<body>
<header>
  <h1>&#127855; HoneyJam Registry Forensics Report</h1>
  <div class="sub">Target: {{ target }} &middot; Generated {{ generated }}</div>
</header>
<div class="wrap">
  <div class="cards">
    <div class="card"><div class="n">{{ total }}</div><div class="l">Findings</div></div>
    {% for sev in ["critical","high","medium","low","info"] %}
    <div class="card"><div class="n">{{ sev_counts.get(sev, 0) }}</div><div class="l">{{ sev }}</div></div>
    {% endfor %}
  </div>

  {% for res in results %}
  <h2>{{ res.plugin }} <span style="font-size:12px;opacity:.6">({{ res.hive_type }})</span></h2>
  <div class="plugin-desc">{{ res.description }}</div>
  {% if res.findings %}
  <table>
    <thead><tr><th>Severity</th><th>Conf</th><th>Title</th><th>Key</th><th>Value</th><th>Data</th><th>Timestamp</th></tr></thead>
    <tbody>
    {% for f in res.findings %}
      <tr>
        <td><span class="sev {{ f.severity.value }}">{{ f.severity.value }}</span></td>
        <td>{{ f.confidence }}</td>
        <td>{{ f.title }}{% if f.indicators %}<br><small style="opacity:.6">{{ f.indicators|join(", ") }}</small>{% endif %}</td>
        <td class="data">{{ f.registry_key or "" }}</td>
        <td class="data">{{ f.value_name or "" }}</td>
        <td class="data">{{ f.value_data if f.value_data is not none else "" }}</td>
        <td>{{ f.timestamp.isoformat() if f.timestamp else "" }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="empty">No findings.{% if res.errors %} ({{ res.errors|join("; ") }}){% endif %}</p>
  {% endif %}
  {% endfor %}
</div>
<footer>Generated by HoneyJam &middot; spiritual successor to RegRipper &middot; parsing via regipy</footer>
</body>
</html>
